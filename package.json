{
  "name": "nasge",
  "version": "1.0.1",
  "description": "A creator-friendly WYSIWYG browser extension for editing Steam community guides",
  "type": "module",
  "scripts": {
    "sync-version": "node scripts/sync-version.js",
    "dev": "npm run sync-version && vite",
    "dev:extension": "npm run sync-version && vite build --watch --mode development",
    "build": "npm run sync-version && npm run type-check && vite build",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview"
  },
  "keywords": [
    "steam",
    "guide",
    "editor",
    "chrome-extension",
    "wysiwyg",
    "bbcode"
  ],
  "author": "JohnS3248",
  "repository": {
    "type": "git",
    "url": "https://github.com/JohnS3248/NASGE.git"
  },
  "bugs": {
    "url": "https://github.com/JohnS3248/NASGE/issues"
  },
  "homepage": "https://github.com/JohnS3248/NASGE#readme",
  "license": "MIT",
  "dependencies": {
    "@tiptap/extension-heading": "^3.9.0",
    "@tiptap/extension-horizontal-rule": "^3.9.0",
    "@tiptap/extension-image": "^3.9.0",
    "@tiptap/extension-link": "^3.9.0",
    "@tiptap/extension-strike": "^3.9.0",
    "@tiptap/extension-table": "^3.9.0",
    "@tiptap/extension-table-cell": "^3.9.0",
    "@tiptap/extension-table-header": "^3.9.0",
    "@tiptap/extension-table-row": "^3.9.0",
    "@tiptap/extension-underline": "^3.9.0",
    "@tiptap/html": "^3.9.1",
    "@tiptap/react": "^3.9.0",
    "@tiptap/starter-kit": "^3.9.0",
    "@types/diff-match-patch": "^1.0.36",
    "diff-match-patch": "^1.0.5",
    "driver.js": "^1.4.0",
    "fake-indexeddb": "^6.2.5",
    "i18next": "^26.0.3",
    "idb": "^8.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.30.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/chrome": "^0.1.27",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "type-fest": "^5.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^2.1.4"
  }
}
